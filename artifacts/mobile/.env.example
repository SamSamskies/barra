# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Get your authtoken from https://dashboard.ngrok.com/get-started/your-authtoken
# When set, Expo's tunnel will use your ngrok account.
NGROK_AUTHTOKEN=

# Claim a free static domain at https://dashboard.ngrok.com/cloud-edge/domains
# When set, the tunnel URL stays the same across restarts (prevents progress loss).
NGROK_STATIC_DOMAIN=
